{
  "name": "@devex/workflow-framework",
  "version": "0.1.0",
  "description": "DevEx Golden Path TypeScript framework for CI/CD pipelines and AWS CDK constructs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "ci": "npm run lint && npm run build && npm test"
  },
  "keywords": [
    "devex",
    "golden-path",
    "cicd",
    "dora",
    "aws-cdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.0.0",
    "@github-actions-workflow-ts/lib": "^2.5.0",
    "aws-cdk-lib": "^2.168.0",
    "constructs": "^10.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "jest": "^29.0.0",
    "pnpm": "^11.8.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
