# Copy this file to .env and adjust values for your local setup.
# .env is gitignored — never commit real credentials.

# Local DynamoDB port (default: 8000)
DYNAMODB_PORT=8000

# AWS region stub for local SDK calls
AWS_REGION=us-east-1

# Local DynamoDB endpoint — used by Python tests and CDK local testing
DYNAMODB_ENDPOINT=http://localhost:8000

# Dummy credentials for DynamoDB Local (required by the SDK, values don't matter)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Optional: work ID prefix for your team (used by devex init --prefix)
DEVEX_WORK_ID_PREFIX=FIN
